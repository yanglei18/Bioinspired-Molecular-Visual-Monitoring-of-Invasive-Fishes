# evidence_grounded_reasoner: keep the small JSON manifests under data/,
# but never commit the bulky videos, released weights, checkpoints or eval dumps.
evidence_grounded_reasoner/data/videos/
evidence_grounded_reasoner/FishVL-4B-Thinking/
